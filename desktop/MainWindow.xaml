<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WorldDownloaderManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="26" MaxWidth="760" HorizontalAlignment="Stretch">

            <StackPanel Orientation="Horizontal" Spacing="14">
                <TextBlock Text="&#x26CF;&#xFE0F;" FontSize="34" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="World Downloader" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Set up and run the web console in Docker"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="True" IsClosable="False"
                     Severity="Informational" Title="Status" Message="Checking Docker…" />

            <!-- Data folder -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Data folder" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Downloaded worlds, the registry cache, your account session and settings are stored here."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox x:Name="FolderBox" IsReadOnly="True" PlaceholderText="Choose a folder…" />
                        <Button x:Name="BrowseBtn" Grid.Column="1" Content="Browse…" Click="Browse_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Configuration -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Configuration" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                        <NumberBox x:Name="WebPortBox" Header="Web console port" Value="8080"
                                   Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" />
                        <NumberBox x:Name="ProxyPortBox" Grid.Column="1" Header="Minecraft proxy port" Value="25565"
                                   Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" />
                    </Grid>
                    <TextBox x:Name="ImageBox" Header="Docker image" />
                    <ToggleSwitch x:Name="LoginSwitch" Header="Require a login to open the console"
                                  Toggled="LoginSwitch_Toggled" />
                    <Grid x:Name="LoginPanel" ColumnDefinitions="*,*" ColumnSpacing="14" Visibility="Collapsed">
                        <TextBox x:Name="UserBox" Header="Console username" />
                        <PasswordBox x:Name="PassBox" Grid.Column="1" Header="Console password" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button x:Name="StartBtn" Style="{StaticResource AccentButtonStyle}" Click="Start_Click" Content="▶  Start" />
                <Button x:Name="StopBtn" Click="Stop_Click" Content="■  Stop" IsEnabled="False" />
                <Button x:Name="OpenBtn" Click="Open_Click" Content="Open console" />
                <Button x:Name="PullBtn" Click="Pull_Click" Content="Update image" />
                <ProgressRing x:Name="Spinner" IsActive="False" Width="22" Height="22" />
            </StackPanel>

            <!-- Output -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Output" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ScrollViewer x:Name="LogScroll" Height="240" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogText" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
